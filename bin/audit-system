#!/usr/bin/env zsh
# audit-system - Comprehensive memory and process analysis for macOS
# Extracted from ~/.zsh/functions/dev.zsh as a standalone script
# Requires: gum (install with: brew install gum)

# Check for gum dependency
if ! command -v gum &>/dev/null; then
  echo "Error: gum is required but not installed."
  echo "Install with: brew install gum"
  exit 1
fi

# Parse arguments
local json_output=false
local mem_threshold=500  # MB
local cpu_threshold=80   # percent
local top_count=10
local use_color=true

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      echo "Usage: audit-system [OPTIONS]"
      echo ""
      echo "Comprehensive memory and process analysis for macOS"
      echo ""
      echo "Options:"
      echo "  --json           Output results in JSON format"
      echo "  --no-color       Disable colored output"
      echo "  --mem-threshold  Memory threshold in MB (default: 500)"
      echo "  --cpu-threshold  CPU threshold in percent (default: 80)"
      echo "  --top N          Show top N processes (default: 10)"
      echo "  --help, -h       Show this help message"
      echo ""
      echo "Examples:"
      echo "  audit-system                      # Run with defaults"
      echo "  audit-system --json               # Output as JSON"
      echo "  audit-system --no-color | less    # Pipe without colors"
      echo "  audit-system --mem-threshold 1000 # Flag processes over 1GB"
      exit 0
      ;;
    --json) json_output=true; shift ;;
    --no-color) use_color=false; shift ;;
    --mem-threshold) mem_threshold="$2"; shift 2 ;;
    --cpu-threshold) cpu_threshold="$2"; shift 2 ;;
    --top) top_count="$2"; shift 2 ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

# Set gum color mode
local gum_env=""
if ! $use_color; then
  gum_env="NO_COLOR=1"
fi

# Progress bar helper
_progress_bar() {
  local pct=$1 width=${2:-20}
  local filled=$(( pct * width / 100 ))
  local empty=$(( width - filled ))
  local bar=""
  local i
  for (( i=0; i<filled; i++ )); do bar+="█"; done
  for (( i=0; i<empty; i++ )); do bar+="░"; done
  echo "$bar"
}

# ═══════════════════════════════════════════════════════════════════════════
# COLLECT SYSTEM METRICS (optimized - single ps call, cached results)
# ═══════════════════════════════════════════════════════════════════════════

# Get memory info efficiently
local page_size=$(sysctl -n hw.pagesize)
local total_mem_bytes=$(sysctl -n hw.memsize)
local total_mem_mb=$((total_mem_bytes / 1024 / 1024))

# Parse vm_stat in one awk call
local vm_stats=$(vm_stat | awk '
  /Pages free/ {gsub(/\./,"",$3); free=$3}
  /Pages active/ {gsub(/\./,"",$3); active=$3}
  /Pages inactive/ {gsub(/\./,"",$3); inactive=$3}
  /Pages speculative/ {gsub(/\./,"",$3); spec=$3}
  /Pages wired down/ {gsub(/\./,"",$4); wired=$4}
  /Pages occupied by compressor/ {gsub(/\./,"",$5); comp=$5}
  END {print free, active, inactive, spec, wired, comp}
')
local pages_free pages_active pages_inactive pages_speculative pages_wired pages_compressed
read pages_free pages_active pages_inactive pages_speculative pages_wired pages_compressed <<< "$vm_stats"

# Handle empty values
: ${pages_free:=0} ${pages_active:=0} ${pages_inactive:=0}
: ${pages_speculative:=0} ${pages_wired:=0} ${pages_compressed:=0}

local free_mem_mb=$(( (pages_free + pages_speculative) * page_size / 1024 / 1024 ))
local active_mem_mb=$(( pages_active * page_size / 1024 / 1024 ))
local inactive_mem_mb=$(( pages_inactive * page_size / 1024 / 1024 ))
local wired_mem_mb=$(( pages_wired * page_size / 1024 / 1024 ))
local compressed_mem_mb=$(( pages_compressed * page_size / 1024 / 1024 ))
local used_mem_mb=$(( total_mem_mb - free_mem_mb ))

# Memory pressure
local mem_pressure="normal"
local mem_percent=$(( used_mem_mb * 100 / total_mem_mb ))
(( mem_percent > 90 )) && mem_pressure="critical"
(( mem_percent > 75 && mem_percent <= 90 )) && mem_pressure="warning"

# Get swap usage in one awk call
local swap_stats=$(sysctl -n vm.swapusage 2>/dev/null | awk '{
  gsub(/M/,"",$3); gsub(/M/,"",$6); gsub(/M/,"",$9);
  print $3, $6, $9
}')
local swap_total swap_used swap_free
read swap_total swap_used swap_free <<< "${swap_stats:-0 0 0}"
: ${swap_total:=0} ${swap_used:=0} ${swap_free:=0}

# Single ps call for all process data - cache it
local ps_cache=$(ps -axo pid=,rss=,pcpu=,user=,stat=,comm= 2>/dev/null)

# Full args for node and Claude/MCP process identification (comm= only gives binary name)
local node_args_cache=$(ps -axo pid=,rss=,pcpu=,ppid=,args= 2>/dev/null | grep -E '/node( |$)|bin/node' | grep -v grep)
local claude_args_cache=$(ps -axo pid=,rss=,pcpu=,ppid=,args= 2>/dev/null | grep -iE '(claude|mcp-server|@modelcontextprotocol)' | grep -v grep)

# Get counts from cached data
local total_procs=$(echo "$ps_cache" | wc -l | tr -d ' ')
local zombie_count=$(echo "$ps_cache" | awk '$5 ~ /Z/ {count++} END {print count+0}')

# Get top memory processes from cache (using awk for efficiency)
local top_mem_procs=$(echo "$ps_cache" | sort -k2 -rn | head -n "$top_count")
local top_cpu_procs=$(echo "$ps_cache" | sort -k3 -rn | head -n "$top_count")

# Get process count by user from cache
local procs_by_user=$(echo "$ps_cache" | awk '{print $4}' | sort | uniq -c | sort -rn)

# Find high memory/CPU processes from cache (threshold in KB for rss)
local mem_thresh_kb=$((mem_threshold * 1024))
local high_mem_procs=$(echo "$ps_cache" | awk -v thresh="$mem_thresh_kb" '$2 >= thresh {print $0}')
local high_cpu_procs=$(echo "$ps_cache" | awk -v thresh="$cpu_threshold" '$3 >= thresh {print $0}')

# Find duplicate processes from cache
local duplicate_procs=$(echo "$ps_cache" | awk '{print $6}' | sort | uniq -c | sort -rn | awk '$1 > 3 {print $0}' | head -10)

# ═══════════════════════════════════════════════════════════════════════════
# CHROME DIAGNOSTICS
# ═══════════════════════════════════════════════════════════════════════════

local chrome_running=false
local chrome_total_mem=0 chrome_total_count=0
local chrome_renderer_count=0 chrome_renderer_mem=0
local chrome_gpu_mem=0 chrome_plugin_mem=0 chrome_utility_mem=0
local chrome_tab_info="" chrome_tab_count=0

if echo "$ps_cache" | grep -q "Google Chrome"; then
  chrome_running=true

  # Process breakdown
  local cr_stats=$(echo "$ps_cache" | awk '
    /Chrome Helper \(Renderer\)/ {rc++; rm+=$2}
    /Chrome Helper \(GPU\)/      {gm+=$2}
    /Chrome Helper \(Plugin\)/   {pm+=$2}
    /Chrome Helper$/             {um+=$2}
    /Google Chrome/              {tc++; tm+=$2}
    END {printf "%d %d %d %d %d %d", tc+0, int(tm/1024), rc+0, int(rm/1024), int(gm/1024), int(pm/1024)}
  ')
  read chrome_total_count chrome_total_mem chrome_renderer_count chrome_renderer_mem chrome_gpu_mem chrome_plugin_mem <<< "$cr_stats"

  # Top Chrome renderers by memory
  local chrome_top_renderers=$(echo "$ps_cache" | awk '/Chrome Helper \(Renderer\)/ {printf "%d %d\n", $1, int($2/1024)}' | sort -k2 -rn | head -5)

  # Try to get actual tab titles/URLs via AppleScript (only if Chrome is responsive)
  chrome_tab_info=$(osascript 2>/dev/null <<'APPLESCRIPT'
    set output to ""
    tell application "System Events"
      if not (exists process "Google Chrome") then return "NOT_RUNNING"
    end tell
    try
      tell application "Google Chrome"
        repeat with w in every window
          repeat with t in every tab of w
            set tabTitle to title of t
            set tabUrl to URL of t
            -- Truncate long titles
            if length of tabTitle > 45 then
              set tabTitle to text 1 thru 45 of tabTitle & "..."
            end if
            -- Extract domain from URL
            set tabDomain to tabUrl
            try
              set AppleScript's text item delimiters to "/"
              set tabDomain to text item 3 of tabUrl
              set AppleScript's text item delimiters to ""
            end try
            set output to output & tabTitle & "\t" & tabDomain & linefeed
          end repeat
        end repeat
      end tell
      return output
    on error
      return "UNRESPONSIVE"
    end try
APPLESCRIPT
  )

  if [[ "$chrome_tab_info" == "NOT_RUNNING" || "$chrome_tab_info" == "UNRESPONSIVE" || -z "$chrome_tab_info" ]]; then
    chrome_tab_info=""
  else
    chrome_tab_count=$(echo "$chrome_tab_info" | grep -c . 2>/dev/null || echo 0)
  fi
fi

# ═══════════════════════════════════════════════════════════════════════════
# VS CODE DIAGNOSTICS
# ═══════════════════════════════════════════════════════════════════════════

local vscode_running=false
local vscode_total_mem=0 vscode_total_count=0
local vscode_plugin_count=0 vscode_plugin_mem=0
local vscode_renderer_mem=0 vscode_gpu_mem=0
local vscode_ext_list="" vscode_ext_count=0
local vscode_top_plugins=""

if echo "$ps_cache" | grep -q "Code Helper"; then
  vscode_running=true

  local vs_stats=$(echo "$ps_cache" | awk '
    /Code Helper \(Plugin\)/   {pc++; pm+=$2}
    /Code Helper \(Renderer\)/ {rm+=$2}
    /Code Helper \(GPU\)/      {gm+=$2}
    /Code Helper|Visual Studio Code|Electron/ {tc++; tm+=$2}
    END {printf "%d %d %d %d %d %d", tc+0, int(tm/1024), pc+0, int(pm/1024), int(rm/1024), int(gm/1024)}
  ')
  read vscode_total_count vscode_total_mem vscode_plugin_count vscode_plugin_mem vscode_renderer_mem vscode_gpu_mem <<< "$vs_stats"

  # Top plugin host processes
  vscode_top_plugins=$(echo "$ps_cache" | awk '/Code Helper \(Plugin\)/ {printf "%d %d\n", $1, int($2/1024)}' | sort -k2 -rn | head -5)

  # Get installed extensions list (with versions)
  if command -v code &>/dev/null; then
    vscode_ext_list=$(code --list-extensions --show-versions 2>/dev/null)
    vscode_ext_count=$(echo "$vscode_ext_list" | grep -c . 2>/dev/null || echo 0)
  fi

  # Parse extension host logs for activation times (most recent session)
  local latest_log_dir=$(ls -td ~/Library/Application\ Support/Code/logs/*/ 2>/dev/null | head -1)
  local vscode_slow_extensions=""
  if [[ -n "$latest_log_dir" ]]; then
    # Find exthost log and extract slow activation entries
    local exthost_log=$(find "$latest_log_dir" -path "*/exthost*" -name "*.log" 2>/dev/null | head -1)
    if [[ -n "$exthost_log" ]]; then
      # Extensions that took >100ms to activate
      vscode_slow_extensions=$(grep -o 'Extension.*activated.*in [0-9]*ms' "$exthost_log" 2>/dev/null | \
        awk -F'[ ]' '{
          # Extract extension name and activation time
          for(i=1;i<=NF;i++) {
            if($i ~ /activated/) {
              for(j=i+1;j<=NF;j++) {
                if($j ~ /^[0-9]+ms$/) {
                  gsub(/ms/,"",$j);
                  if($j+0 > 100) print $j+0 "ms " $2
                }
              }
            }
          }
        }' | sort -rn | head -10)
    fi
  fi
fi

# ═══════════════════════════════════════════════════════════════════════════
# GENERATE OUTPUT
# ═══════════════════════════════════════════════════════════════════════════

if $json_output; then
  # Build JSON arrays efficiently with awk
  local mem_json=$(echo "$top_mem_procs" | head -5 | awk '{
    pid=$1; rss=$2; cpu=$3; user=$4; cmd=$6;
    mem_mb=int(rss/1024);
    printf "    {\"pid\": %d, \"memory_mb\": %d, \"cpu_percent\": %s, \"user\": \"%s\", \"command\": \"%s\"}", pid, mem_mb, cpu, user, cmd;
    if (NR < 5) printf ",";
    printf "\n"
  }')

  local cpu_json=$(echo "$top_cpu_procs" | head -5 | awk '{
    pid=$1; rss=$2; cpu=$3; user=$4; cmd=$6;
    mem_mb=int(rss/1024);
    printf "    {\"pid\": %d, \"memory_mb\": %d, \"cpu_percent\": %s, \"user\": \"%s\", \"command\": \"%s\"}", pid, mem_mb, cpu, user, cmd;
    if (NR < 5) printf ",";
    printf "\n"
  }')

  cat <<EOF
{
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "system": {
    "memory": {
      "total_mb": $total_mem_mb,
      "used_mb": $used_mem_mb,
      "free_mb": $free_mem_mb,
      "active_mb": $active_mem_mb,
      "inactive_mb": $inactive_mem_mb,
      "wired_mb": $wired_mem_mb,
      "compressed_mb": $compressed_mem_mb,
      "percent_used": $mem_percent,
      "pressure": "$mem_pressure"
    },
    "swap": {
      "total_mb": ${swap_total:-0},
      "used_mb": ${swap_used:-0},
      "free_mb": ${swap_free:-0}
    },
    "processes": {
      "total": $total_procs,
      "zombies": $zombie_count
    }
  },
  "top_memory_processes": [
$mem_json
  ],
  "top_cpu_processes": [
$cpu_json
  ],
  "chrome": {
    "running": $chrome_running,
    "total_memory_mb": $chrome_total_mem,
    "total_processes": $chrome_total_count,
    "renderer_count": $chrome_renderer_count,
    "renderer_memory_mb": $chrome_renderer_mem,
    "gpu_memory_mb": $chrome_gpu_mem,
    "tab_count": $chrome_tab_count
  },
  "vscode": {
    "running": $vscode_running,
    "total_memory_mb": $vscode_total_mem,
    "total_processes": $vscode_total_count,
    "extension_host_count": $vscode_plugin_count,
    "extension_host_memory_mb": $vscode_plugin_mem,
    "installed_extensions": $vscode_ext_count
  },
  "issues": [],
  "recommendations": []
}
EOF
  exit 0
fi

# ═══════════════════════════════════════════════════════════════════════════
# HUMAN-READABLE OUTPUT (using gum)
# ═══════════════════════════════════════════════════════════════════════════

# Set color mode for gum
local -a gum_opts=()
if ! $use_color; then
  export NO_COLOR=1
fi

# Header
env ${gum_env:-} gum style --border double --border-foreground 6 --align center --padding "0 2" --width 78 \
  "SYSTEM AUDIT REPORT" "$(date '+%Y-%m-%d %H:%M:%S')"
echo ""

# Memory Dashboard
local mem_bar=$(_progress_bar "$mem_percent" 20)
local pressure_label
local pressure_color
case "$mem_pressure" in
  critical) pressure_label="CRITICAL"; pressure_color=1 ;;
  warning)  pressure_label="WARNING"; pressure_color=3 ;;
  *)        pressure_label="NORMAL"; pressure_color=2 ;;
esac

local mem_content
mem_content=$(printf "%s %d%%  Used: %d MB / %d MB  Free: %d MB\n" "$mem_bar" "$mem_percent" "$used_mem_mb" "$total_mem_mb" "$free_mem_mb")
mem_content+=$(printf "\nActive: %d MB  Inactive: %d MB  Wired: %d MB  Comp: %d MB" "$active_mem_mb" "$inactive_mem_mb" "$wired_mem_mb" "$compressed_mem_mb")
mem_content+=$(printf "\nPressure: ")

env ${gum_env:-} gum style --border rounded --border-foreground 6 --padding "0 1" --width 78 \
  "$(env ${gum_env:-} gum style --bold 'MEMORY OVERVIEW')" \
  "$mem_content$(env ${gum_env:-} gum style --foreground $pressure_color --bold "$pressure_label")"
echo ""

# Swap Dashboard
local swap_pct=0
if (( ${swap_total%.*} > 0 )); then
  swap_pct=$(( ${swap_used%.*} * 100 / ${swap_total%.*} ))
fi
local swap_bar=$(_progress_bar "$swap_pct" 10)

env ${gum_env:-} gum style --border rounded --border-foreground 6 --padding "0 1" --width 78 \
  "$(env ${gum_env:-} gum style --bold 'SWAP USAGE')" \
  "$(printf "%s %d%%  Used: %.1f MB / %.1f MB  Free: %.1f MB" "$swap_bar" "$swap_pct" "${swap_used:-0}" "${swap_total:-0}" "${swap_free:-0}")"
echo ""

# Process Summary
env ${gum_env:-} gum style --border rounded --border-foreground 6 --padding "0 1" --width 78 \
  "$(env ${gum_env:-} gum style --bold 'PROCESS SUMMARY')" \
  "$(printf "Total Processes: %d    Zombies: %d" "$total_procs" "$zombie_count")"
echo ""

# Top Memory Consumers - using gum table
local mem_csv="PID,MEM,CPU,USER,COMMAND"
mem_csv+="\n$(echo "$top_mem_procs" | awk '{
  pid=$1; rss=$2; cpu=$3; user=$4; cmd=$6;
  mem_mb=int(rss/1024);
  n=split(cmd, parts, "/");
  short_cmd=parts[n];
  if (length(short_cmd) > 20) short_cmd=substr(short_cmd,1,17)"...";
  if (length(user) > 10) user=substr(user,1,7)"...";
  printf "%d,%dMB,%.1f%%,%s,%s\n", pid, mem_mb, cpu, user, short_cmd
}')"

echo "$(env ${gum_env:-} gum style --bold --foreground 6 'TOP MEMORY CONSUMERS')"
echo -e "$mem_csv" | env ${gum_env:-} gum table --print --border rounded --border.foreground 6
echo ""

# Top CPU Consumers - using gum table
local cpu_csv="PID,MEM,CPU,USER,COMMAND"
cpu_csv+="\n$(echo "$top_cpu_procs" | awk '{
  pid=$1; rss=$2; cpu=$3; user=$4; cmd=$6;
  mem_mb=int(rss/1024);
  n=split(cmd, parts, "/");
  short_cmd=parts[n];
  if (length(short_cmd) > 20) short_cmd=substr(short_cmd,1,17)"...";
  if (length(user) > 10) user=substr(user,1,7)"...";
  printf "%d,%dMB,%.1f%%,%s,%s\n", pid, mem_mb, cpu, user, short_cmd
}')"

echo "$(env ${gum_env:-} gum style --bold --foreground 6 'TOP CPU CONSUMERS')"
echo -e "$cpu_csv" | env ${gum_env:-} gum table --print --border rounded --border.foreground 6
echo ""

# ═══════════════════════════════════════════════════════════════════════════
# CHROME DIAGNOSTICS DISPLAY
# ═══════════════════════════════════════════════════════════════════════════

if $chrome_running; then
  local chrome_content="Total: ${chrome_total_mem}MB across ${chrome_total_count} processes"
  chrome_content+=$(printf "\nRenderers (tabs): %d procs, %dMB  |  GPU: %dMB  |  Plugins: %dMB" \
    "$chrome_renderer_count" "$chrome_renderer_mem" "$chrome_gpu_mem" "$chrome_plugin_mem")

  if [[ -n "$chrome_tab_info" ]]; then
    chrome_content+="\n"
    # Build tab table: TITLE, DOMAIN
    local tab_csv="TITLE,DOMAIN"
    tab_csv+="\n$(echo "$chrome_tab_info" | awk -F'\t' 'NF>=2 {
      title=$1; domain=$2;
      gsub(/,/, " ", title); gsub(/,/, " ", domain);
      if (length(title) > 45) title=substr(title,1,42)"...";
      if (length(domain) > 35) domain=substr(domain,1,32)"...";
      printf "%s,%s\n", title, domain
    }')"
    chrome_content+="\n$(echo -e "$tab_csv" | env ${gum_env:-} gum table --print --border normal --border.foreground 3)"
  elif (( chrome_renderer_count > 0 )); then
    chrome_content+="\n\n(Chrome unresponsive to AppleScript — tab names unavailable)"
    chrome_content+="\nHeaviest renderer processes:"
    while IFS=' ' read -r pid mem; do
      [[ -z "$pid" ]] && continue
      chrome_content+=$(printf "\n  PID %-8d %dMB" "$pid" "$mem")
    done <<< "$chrome_top_renderers"
  fi

  env ${gum_env:-} gum style --border rounded --border-foreground 3 --padding "0 1" --width 78 \
    "$(env ${gum_env:-} gum style --bold --foreground 3 'CHROME DIAGNOSTICS')" \
    "$(echo -e "$chrome_content")"
  echo ""
fi

# ═══════════════════════════════════════════════════════════════════════════
# VS CODE DIAGNOSTICS DISPLAY
# ═══════════════════════════════════════════════════════════════════════════

if $vscode_running; then
  local vscode_content="Total: ${vscode_total_mem}MB across ${vscode_total_count} processes"
  vscode_content+=$(printf "\nExtension hosts: %d procs, %dMB  |  Renderers: %dMB  |  GPU: %dMB" \
    "$vscode_plugin_count" "$vscode_plugin_mem" "$vscode_renderer_mem" "$vscode_gpu_mem")

  if (( vscode_ext_count > 0 )); then
    vscode_content+="\nInstalled extensions: ${vscode_ext_count}"
  fi

  # Show heaviest extension host processes
  if [[ -n "$vscode_top_plugins" ]]; then
    vscode_content+="\n\nHeaviest extension hosts:"
    while IFS=' ' read -r pid mem; do
      [[ -z "$pid" ]] && continue
      vscode_content+=$(printf "\n  PID %-8d %dMB" "$pid" "$mem")
    done <<< "$vscode_top_plugins"
  fi

  # Show slow-activating extensions from logs
  if [[ -n "$vscode_slow_extensions" ]]; then
    vscode_content+="\n\nSlow-activating extensions (>100ms, from logs):"
    while read -r line; do
      [[ -z "$line" ]] && continue
      vscode_content+="\n  $line"
    done <<< "$vscode_slow_extensions"
  fi

  # Show all installed extensions grouped
  if [[ -n "$vscode_ext_list" ]]; then
    vscode_content+="\n\nInstalled extensions:"
    local ext_csv="EXTENSION,VERSION"
    ext_csv+="\n$(echo "$vscode_ext_list" | awk -F'@' '{
      ext=$1; ver=$2;
      if (length(ext) > 45) ext=substr(ext,1,42)"...";
      printf "%s,%s\n", ext, ver
    }' | head -30)"
    if (( vscode_ext_count > 30 )); then
      ext_csv+="\n...and $((vscode_ext_count - 30)) more,"
    fi
    vscode_content+="\n$(echo -e "$ext_csv" | env ${gum_env:-} gum table --print --border normal --border.foreground 5)"
  fi

  env ${gum_env:-} gum style --border rounded --border-foreground 5 --padding "0 1" --width 78 \
    "$(env ${gum_env:-} gum style --bold --foreground 5 'VS CODE DIAGNOSTICS')" \
    "$(echo -e "$vscode_content")"
  echo ""
fi

# ═══════════════════════════════════════════════════════════════════════════
# NODE DIAGNOSTICS
# ═══════════════════════════════════════════════════════════════════════════

if [[ -n "$node_args_cache" ]]; then
  local node_total_count=$(echo "$node_args_cache" | wc -l | tr -d ' ')
  local node_total_mem=$(echo "$node_args_cache" | awk '{sum+=$2} END {printf "%d", sum/1024}')

  # Group by binary path origin
  local node_homebrew=$(echo "$node_args_cache" | grep '/opt/homebrew')
  local node_mise_shim=$(echo "$node_args_cache" | grep '/.local/share/mise/shims/')
  local node_mise_hardcoded=$(echo "$node_args_cache" | grep '/.local/share/mise/installs/')
  local node_other=$(echo "$node_args_cache" | grep -v '/opt/homebrew' | grep -v '/.local/share/mise')

  # shared awk formatter: pid ppid script — reused across all groups
  _node_proc_lines() {
    awk '{
      pid=$1; ppid=$4;
      args=$0; gsub(/^[^ ]+ +[^ ]+ +[^ ]+ +[^ ]+ +/, "", args);
      n=split(args, parts, " ");
      bin=parts[1]; script=(n>1 ? parts[2] : "(no args)");
      nb=split(bin, bparts, "/"); short_bin=bparts[nb];
      ns=split(script, sparts, "/"); short_script=sparts[ns];
      if (length(short_script) > 40) short_script=substr(short_script,1,37)"...";
      printf "  PID %-7d ppid=%-7d %-10s %s\n", pid, ppid, short_bin, short_script
    }'
  }

  local node_content="Total: ${node_total_mem}MB across ${node_total_count} processes"

  if [[ -n "$node_homebrew" ]]; then
    local hb_count=$(echo "$node_homebrew" | wc -l | tr -d ' ')
    local hb_mem=$(echo "$node_homebrew" | awk '{sum+=$2} END {printf "%d", sum/1024}')
    node_content+="\n$(gum style --foreground 1 --bold '[ERROR]') Homebrew node: ${hb_count} proc(s), ${hb_mem}MB"
    node_content+="\n$(echo "$node_homebrew" | _node_proc_lines)"
  fi

  if [[ -n "$node_mise_hardcoded" ]]; then
    local hc_count=$(echo "$node_mise_hardcoded" | wc -l | tr -d ' ')
    local hc_mem=$(echo "$node_mise_hardcoded" | awk '{sum+=$2} END {printf "%d", sum/1024}')
    node_content+="\n$(gum style --foreground 3 --bold '[WARN]') Hardcoded mise installs path: ${hc_count} proc(s), ${hc_mem}MB"
    node_content+="\n  (bypasses mise version resolution — config should use shims/ not installs/)"
    node_content+="\n$(echo "$node_mise_hardcoded" | _node_proc_lines)"
  fi

  if [[ -n "$node_mise_shim" ]]; then
    local ms_count=$(echo "$node_mise_shim" | wc -l | tr -d ' ')
    local ms_mem=$(echo "$node_mise_shim" | awk '{sum+=$2} END {printf "%d", sum/1024}')
    node_content+="\n$(gum style --foreground 2 '[OK]') mise shim: ${ms_count} proc(s), ${ms_mem}MB"
    node_content+="\n$(echo "$node_mise_shim" | _node_proc_lines)"
  fi

  if [[ -n "$node_other" ]]; then
    local ot_count=$(echo "$node_other" | wc -l | tr -d ' ')
    local ot_mem=$(echo "$node_other" | awk '{sum+=$2} END {printf "%d", sum/1024}')
    node_content+="\n$(gum style --foreground 4 '[INFO]') Other/system node: ${ot_count} proc(s), ${ot_mem}MB"
    node_content+="\n$(echo "$node_other" | _node_proc_lines)"
  fi

  env ${gum_env:-} gum style --border rounded --border-foreground 3 --padding "0 1" --width 78 \
    "$(env ${gum_env:-} gum style --bold --foreground 3 'NODE DIAGNOSTICS')" \
    "$(echo -e "$node_content")"
  echo ""
fi

# ═══════════════════════════════════════════════════════════════════════════
# CLAUDE CODE DIAGNOSTICS
# ═══════════════════════════════════════════════════════════════════════════

local claude_procs=$(echo "$ps_cache" | grep -i 'claude\|mcp')
if [[ -n "$claude_procs" ]] || [[ -n "$claude_args_cache" ]]; then
  local claude_total_count=$(echo "$claude_procs" | grep -c . 2>/dev/null || echo 0)
  local claude_total_mem=$(echo "$claude_procs" | awk '{sum+=$2} END {printf "%d", sum/1024}')

  local claude_content="Total: ${claude_total_mem}MB across ${claude_total_count} processes"

  # MCP servers with node binary details
  if [[ -n "$claude_args_cache" ]]; then
    local mcp_count=$(echo "$claude_args_cache" | wc -l | tr -d ' ')
    claude_content+="\n\nMCP / Claude node processes (${mcp_count}):"
    claude_content+="\n$(echo "$claude_args_cache" | awk '{
      pid=$1; rss=$2; ppid=$4;
      args=$0; gsub(/^[^ ]+ +[^ ]+ +[^ ]+ +[^ ]+ +/, "", args);
      n=split(args, parts, " ");
      bin=parts[1]; script=(n>1 ? parts[2] : "");
      nb=split(bin, bparts, "/"); short_bin=bparts[nb];
      # flag homebrew node
      origin="mise";
      if (bin ~ /opt\/homebrew/) origin="[HOMEBREW]";
      else if (bin ~ /\.local\/share\/mise/) origin="mise";
      ns=split(script, sparts, "/"); short_script=sparts[ns];
      if (length(short_script) > 35) short_script=substr(short_script,1,32)"...";
      mem_mb=int(rss/1024);
      printf "  PID %-7d ppid=%-7d %dMB  %-12s %s\n", pid, ppid, mem_mb, origin, short_script
    }')"
  fi

  env ${gum_env:-} gum style --border rounded --border-foreground 5 --padding "0 1" --width 78 \
    "$(env ${gum_env:-} gum style --bold --foreground 5 'CLAUDE CODE DIAGNOSTICS')" \
    "$(echo -e "$claude_content")"
  echo ""
fi

# ═══════════════════════════════════════════════════════════════════════════
# DETECTED ISSUES
# ═══════════════════════════════════════════════════════════════════════════

local issues=""

# Check memory pressure
if [[ "$mem_pressure" == "critical" ]]; then
  issues+="$(env ${gum_env:-} gum style --foreground 1 --bold '[CRITICAL]') Memory pressure is critical (${mem_percent}% used)\n"
elif [[ "$mem_pressure" == "warning" ]]; then
  issues+="$(env ${gum_env:-} gum style --foreground 3 '[WARNING]') Memory pressure elevated (${mem_percent}% used)\n"
fi

# Check swap usage
if (( ${swap_used%.*} > 1000 )); then
  issues+="$(env ${gum_env:-} gum style --foreground 3 '[WARNING]') High swap usage: ${swap_used%.*}MB\n"
fi

# Check Chrome
if $chrome_running; then
  if (( chrome_total_mem > 2000 )); then
    issues+="$(env ${gum_env:-} gum style --foreground 1 --bold '[CRITICAL]') Chrome using ${chrome_total_mem}MB"
    (( chrome_tab_count > 0 )) && issues+=" (${chrome_tab_count} tabs)"
    (( chrome_tab_count == 0 && chrome_renderer_count > 0 )) && issues+=" (~${chrome_renderer_count} tabs)"
    issues+="\n"
  elif (( chrome_total_mem > 1000 )); then
    issues+="$(env ${gum_env:-} gum style --foreground 3 '[WARNING]') Chrome using ${chrome_total_mem}MB"
    (( chrome_tab_count > 0 )) && issues+=" (${chrome_tab_count} tabs)"
    issues+="\n"
  fi
  if (( chrome_renderer_count > 20 )); then
    issues+="$(env ${gum_env:-} gum style --foreground 3 '[WARNING]') ${chrome_renderer_count} Chrome renderer processes — excessive tab count\n"
  fi
fi

# Check VS Code
if $vscode_running; then
  if (( vscode_total_mem > 3000 )); then
    issues+="$(env ${gum_env:-} gum style --foreground 1 --bold '[CRITICAL]') VS Code using ${vscode_total_mem}MB (${vscode_plugin_count} extension hosts, ${vscode_ext_count} extensions)\n"
  elif (( vscode_total_mem > 1500 )); then
    issues+="$(env ${gum_env:-} gum style --foreground 3 '[WARNING]') VS Code using ${vscode_total_mem}MB (${vscode_plugin_count} extension hosts, ${vscode_ext_count} extensions)\n"
  fi
  if (( vscode_ext_count > 40 )); then
    issues+="$(env ${gum_env:-} gum style --foreground 3 '[WARNING]') ${vscode_ext_count} VS Code extensions installed — likely too many\n"
  fi
  # Check for individual heavy extension hosts (>500MB)
  local heavy_ext=$(echo "$ps_cache" | awk '/Code Helper \(Plugin\)/ && $2/1024 > 500 {printf "PID %d (%dMB) ", $1, $2/1024}')
  if [[ -n "$heavy_ext" ]]; then
    issues+="$(env ${gum_env:-} gum style --foreground 3 '[WARNING]') Heavy VS Code extension host(s): ${heavy_ext}\n"
  fi
fi

# Check for Homebrew node (unexpected when mise is the runtime manager)
if [[ -n "$node_args_cache" ]] && echo "$node_args_cache" | grep -q '/opt/homebrew'; then
  local hb_node_count=$(echo "$node_args_cache" | grep -c '/opt/homebrew')
  issues+="$(env ${gum_env:-} gum style --foreground 1 --bold '[ERROR]') ${hb_node_count} process(es) using Homebrew node — expected mise shim. See NODE DIAGNOSTICS.\n"
fi

# Check for hardcoded mise installs path (bypasses version resolution)
if [[ -n "$node_args_cache" ]] && echo "$node_args_cache" | grep -q '/.local/share/mise/installs/'; then
  local hc_node_count=$(echo "$node_args_cache" | grep -c '/.local/share/mise/installs/')
  issues+="$(env ${gum_env:-} gum style --foreground 3 '[WARNING]') ${hc_node_count} process(es) using hardcoded mise installs/ path — config should reference mise shims/ instead. See NODE DIAGNOSTICS.\n"
fi

# Check zombies
if (( zombie_count > 0 )); then
  issues+="$(env ${gum_env:-} gum style --foreground 4 '[INFO]') ${zombie_count} zombie process(es) detected\n"
fi

# Check high memory processes
if [[ -n "$high_mem_procs" ]]; then
  local count=$(echo "$high_mem_procs" | wc -l | tr -d ' ')
  issues+="$(env ${gum_env:-} gum style --foreground 3 '[WARNING]') ${count} process(es) exceeding ${mem_threshold}MB memory threshold\n"
fi

# Check high CPU processes
if [[ -n "$high_cpu_procs" ]]; then
  local count=$(echo "$high_cpu_procs" | wc -l | tr -d ' ')
  issues+="$(env ${gum_env:-} gum style --foreground 3 '[WARNING]') ${count} process(es) exceeding ${cpu_threshold}% CPU threshold\n"
fi

# Check for duplicate processes
if [[ -n "$duplicate_procs" ]]; then
  issues+="$(env ${gum_env:-} gum style --foreground 4 '[INFO]') Multiple duplicate process groups detected\n"
fi

if [[ -z "$issues" ]]; then
  issues="$(env ${gum_env:-} gum style --foreground 2 '[OK]') No significant issues detected"
fi

env ${gum_env:-} gum style --border rounded --border-foreground 6 --padding "0 1" --width 78 \
  "$(env ${gum_env:-} gum style --bold 'DETECTED ISSUES')" \
  "$(echo -e "$issues")"
echo ""

# ═══════════════════════════════════════════════════════════════════════════
# RECOMMENDED ACTIONS
# ═══════════════════════════════════════════════════════════════════════════

local recs=""
local rec_count=0

# Chrome recommendations
if $chrome_running && (( chrome_total_mem > 500 )); then
  (( rec_count++ ))
  recs+="${rec_count}. Chrome: ${chrome_total_mem}MB"
  (( chrome_tab_count > 0 )) && recs+=" across ${chrome_tab_count} tabs"
  (( chrome_tab_count == 0 && chrome_renderer_count > 0 )) && recs+=" (~${chrome_renderer_count} tabs)"
  recs+="\n"
  if (( chrome_renderer_count > 15 )); then
    recs+="   Close unused tabs — open the discards page to see per-tab memory:\n"
    recs+="   Command: open -a 'Google Chrome' 'chrome://discards'\n"
  fi
  if (( chrome_total_mem > 1500 )); then
    # Suggest killing heaviest renderer
    local heaviest_cr_pid=$(echo "$chrome_top_renderers" | head -1 | awk '{print $1}')
    local heaviest_cr_mem=$(echo "$chrome_top_renderers" | head -1 | awk '{print $2}')
    if [[ -n "$heaviest_cr_pid" ]] && (( heaviest_cr_mem > 150 )); then
      recs+="   Kill heaviest tab renderer:\n"
      recs+="   Command: kill ${heaviest_cr_pid}  # ${heaviest_cr_mem}MB — tab will show 'Aw Snap'\n"
    fi
    recs+="   Or restart Chrome entirely:\n"
    recs+="   Command: osascript -e 'tell application \"Google Chrome\" to quit' && sleep 2 && open -a 'Google Chrome'\n"
  fi
  recs+="\n"
fi

# VS Code recommendations
if $vscode_running && (( vscode_total_mem > 500 )); then
  (( rec_count++ ))
  recs+="${rec_count}. VS Code: ${vscode_total_mem}MB (${vscode_plugin_count} extension hosts, ${vscode_ext_count} extensions)\n"
  if (( vscode_ext_count > 30 )); then
    recs+="   Too many extensions (${vscode_ext_count}) — list and audit:\n"
    recs+="   Command: code --list-extensions --show-versions\n"
    recs+="   Uninstall unused extensions:\n"
    recs+="   Command: code --uninstall-extension <publisher.extension>\n"
  fi
  # Suggest killing heaviest extension host
  local heaviest_vs_pid=$(echo "$vscode_top_plugins" | head -1 | awk '{print $1}')
  local heaviest_vs_mem=$(echo "$vscode_top_plugins" | head -1 | awk '{print $2}')
  if [[ -n "$heaviest_vs_pid" ]] && (( heaviest_vs_mem > 300 )); then
    recs+="   Kill heaviest extension host (will auto-restart):\n"
    recs+="   Command: kill ${heaviest_vs_pid}  # ${heaviest_vs_mem}MB\n"
  fi
  if (( vscode_total_mem > 2000 )); then
    recs+="   Restart VS Code without extensions to isolate the problem:\n"
    recs+="   Command: code --disable-extensions\n"
    recs+="   Or restart all VS Code processes:\n"
    recs+="   Command: kill-code --dry-run\n"
  else
    recs+="   Restart VS Code to reclaim memory:\n"
    recs+="   Command: kill-code --dry-run\n"
  fi
  recs+="\n"
fi

# Check for node processes
local node_stats=$(echo "$ps_cache" | awk -v IGNORECASE=1 '/node/ {count++; sum+=$2} END {printf "%d %d", count, sum/1024}')
local node_procs node_mem
read node_procs node_mem <<< "$node_stats"
if (( node_procs > 5 )) && (( node_mem > 200 )); then
  (( rec_count++ ))
  recs+="${rec_count}. Kill excess node processes (${node_procs} instances, ~${node_mem}MB)\n"
  recs+="   Command: kill-runaway node --dry-run\n\n"
fi

# Check for MySQL
local mysql_stats=$(echo "$ps_cache" | awk '/mysql/ {count++; sum+=$2} END {printf "%d %d", count, sum/1024}')
local mysql_count mysql_mem
read mysql_count mysql_mem <<< "$mysql_stats"
if (( mysql_count > 0 )); then
  (( rec_count++ ))
  recs+="${rec_count}. MySQL is running (${mysql_count} process(es), ~${mysql_mem}MB)\n"
  recs+="   Command: killmysql --dry-run\n\n"
fi

# High memory processes - use awk to build recommendations
if [[ -n "$high_mem_procs" ]]; then
  local high_mem_recs=$(echo "$high_mem_procs" | head -3 | awk -v start_count="$rec_count" '{
    pid=$1; rss=$2; cmd=$6;
    mem_mb=int(rss/1024);
    n=split(cmd, parts, "/");
    full_cmd=parts[n];
    display_cmd=full_cmd;
    if (length(display_cmd) > 20) display_cmd=substr(display_cmd,1,17)"...";
    start_count++;
    printf "%d. Kill %s (PID %d) to recover ~%dMB\\n", start_count, display_cmd, pid, mem_mb;
    printf "   Command: kill-runaway %s --dry-run\\n\\n", full_cmd;
  }')
  recs+="$high_mem_recs"
  rec_count=$((rec_count + $(echo "$high_mem_procs" | head -3 | wc -l)))
fi

if (( rec_count == 0 )); then
  recs="System appears healthy. No immediate actions recommended."
fi

env ${gum_env:-} gum style --border rounded --border-foreground 6 --padding "0 1" --width 78 \
  "$(env ${gum_env:-} gum style --bold 'RECOMMENDED ACTIONS')" \
  "$(echo -e "$recs")"
echo ""

# ═══════════════════════════════════════════════════════════════════════════
# PROCESSES BY USER
# ═══════════════════════════════════════════════════════════════════════════

local users_content=$(echo "$procs_by_user" | head -5 | awk '{printf "%s %s\n", $1, $2}')

env ${gum_env:-} gum style --border rounded --border-foreground 6 --padding "0 1" --width 78 \
  "$(env ${gum_env:-} gum style --bold 'PROCESSES BY USER')" \
  "$users_content"

# Clean up
unset NO_COLOR 2>/dev/null || true
