export EDITOR=vi

export COMPOSER_MEMORY_LIMIT=-1
export COMPOSER_EXIT_ON_PATCH_FAILURE=0

export DOCKER_CLIENT_TIMEOUT=2000
export COMPOSE_HTTP_TIMEOUT=2000
export BAT_THEME="Sublime Snazzy"


export IP_AGCDN='151.101.2.133'
export IP_FE1='23.185.0.1'
export IP_FE2='23.185.0.2'
export IP_FE3='23.185.0.3'
export IP_FE4='23.185.0.4'
export IP_FE253='23.185.0.253'
export IP_AGCDN2='151.101.2.228'
export CNAME_AGCDN='pantheon-systems.map.fastly.net'
export CNAME_AGCDN2='advcdn-pantheon.map.fastly.net'
export MCFLY_RESULTS=50

if [[ "$(defaults read -g AppleInterfaceStyle 2&>/dev/null)" != "Dark" ]]; then
    export MCFLY_LIGHT=TRUE
fi

export CARGO_BUILD_JOBS=4

export ANTHROPIC_DEFAULT_HAIKU_MODEL="claude-haiku-4-5@20251001"
export ANTHROPIC_DEFAULT_MODEL="claude-sonnet-4-5@20250929"
export ANTHROPIC_DEFAULT_OPUS_MODEL="claude-opus-4-5@20251101"
export ANTHROPIC_DEFAULT_SONNET_MODEL="claude-sonnet-4-5@20250929"


# GitHub token (stored securely in macOS Keychain)
# Added by security fix script
export HOMEBREW_GITHUB_API_TOKEN=$(security find-generic-password -a "$USER" -s "homebrew-github-token" -w 2>/dev/null)
