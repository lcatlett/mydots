export EDITOR=vi


# Add `~/bin` to the `$PATH`
export PATH="$HOME/bin:$PATH";

#export NVM_DIR="$HOME/.nvm"



LOCAL_BIN_EXPORT="$HOME/.local/bin"
YARN_BIN_EXPORT="$HOME/.config/yarn/global/node_modules/.bin"
COMPOSER_BIN_EXPORT="$HOME/.composer/vendor/bin"



# Base PATH
PATH=/usr/local/bin:/usr/local/sbin:/sbin:/usr/sbin:/bin:/usr/bin

# Conditional PATH additions
for path_candidate in /opt/local/sbin \
  $DOTFILES_EXPORT \
  $YARN_BIN_EXPORT \
  $LOCAL_BIN_EXPORT \
  $LOCAL_SBIN_EXPORT \
  $COMPOSER_BIN_EXPORT \
  $YARN_BIN_EXPORT \
  /opt/local/bin \
  /usr/local/share/npm/bin \
  ~/bin \
  /opt/homebrew/opt/gnu-sed/libexec/gnubin
do
  if [ -d ${path_candidate} ]; then
    export PATH=${PATH}:${path_candidate}
  fi
done
#export PATH=$HOME/.composer/vendor/bin:$PATH

export PATH="$PATH:$HOME/.composer/vendor/bin"

#PATH="$(composer config -g home)/vendor/bin:$PATH"
export PATH="/usr/local/opt/curl/bin:$PATH"

export COMPOSER_MEMORY_LIMIT=-1
export COMPOSER_EXIT_ON_PATCH_FAILURE=0
export HOMEBREW_GITHUB_API_TOKEN=[REDACTED]

# Allow for using go get path@version - this will be deprecated in go 1.17
export GO111MODULE=on

export COMPOSER_MEMORY_LIMIT=-1

export DOCKER_CLIENT_TIMEOUT=2000
export COMPOSE_HTTP_TIMEOUT=2000
export BAT_THEME="Sublime Snazzy"


export IP_AGCDN='151.101.2.133'
export IP_FE1='23.185.0.1'
export IP_FE2='23.185.0.2'
export IP_FE3='23.185.0.3'
export IP_FE4='23.185.0.4'
export IP_FE253='23.185.0.253'
export IP_AGCDN2='151.101.2.228'
export CNAME_AGCDN='pantheon-systems.map.fastly.net'
export CNAME_AGCDN2='advcdn-pantheon.map.fastly.net'
export NVM_LAZY_LOAD=true


